generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  reviews Review[]
  lists   List[]

  following Follows[] @relation("following")
  followers Follows[] @relation("followers")

  movieRelations MovieUser[]
}

model Movie {
  id          String    @id @default(uuid())
  tmdbId      Int       @unique
  title       String
  description String?
  posterPath  String?
  releaseDate DateTime?

  reviews Review[]
  users   MovieUser[]
  lists   ListMovie[]
}

model Review {
  id        String   @id @default(uuid())
  content   String
  rating    Float // 0 a 5
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  movie   Movie  @relation(fields: [movieId], references: [id])
  movieId String
}

model List {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  movies ListMovie[]
}

model ListMovie {
  id String @id @default(uuid())

  list   List   @relation(fields: [listId], references: [id])
  listId String

  movie   Movie  @relation(fields: [movieId], references: [id])
  movieId String
}

model MovieUser {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  movie   Movie  @relation(fields: [movieId], references: [id])
  movieId String

  type MovieUserType
}

enum MovieUserType {
  WATCHED
  FAVORITE
}

model Follows {
  id String @id @default(uuid())

  follower   User   @relation("followers", fields: [followerId], references: [id])
  followerId String

  following   User   @relation("following", fields: [followingId], references: [id])
  followingId String
}
